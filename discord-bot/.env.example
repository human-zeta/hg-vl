# Token del bot de Discord (Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=

# ID del servidor (guild) de Discord — clic derecho en el servidor con modo desarrollador activado
DISCORD_GUILD_ID=1481427371574824973

# Client ID de la app de Discord (Developer Portal → OAuth2)
DISCORD_CLIENT_ID=1513649897352466563

# IDs de los roles a asignar según el tier de suscripción
DISCORD_ROLE_T1=
DISCORD_ROLE_T2=
DISCORD_ROLE_T3=

# URL de la Realtime Database de Firebase
FIREBASE_DB_URL=https://hg-vl-shaders-default-rtdb.firebaseio.com

# Credenciales de Firebase Admin SDK (Project settings → Service accounts → Generate new private key)
# Pegar el contenido completo del JSON en una sola línea
FIREBASE_SERVICE_ACCOUNT=

# Mapeo de plan_id de MercadoPago a tier (1, 2 o 3)
MP_PLAN_TIER_2=0123da920c4e46b2afcb334868e722ed
MP_PLAN_TIER_3=d0c05031038f487b9978cb16af3e8135

# Token de acceso de MercadoPago (para consultar detalles del pago/suscripción vía API)
MP_ACCESS_TOKEN=

# Secret opcional para validar el webhook de MercadoPago (si se configura)
MP_WEBHOOK_SECRET=

# Puerto del servidor
PORT=3000
